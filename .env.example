# 1min-proxy Konfiguration
# Kopieren nach .env und anpassen

# Bind-Adresse und Port
PROXY_HOST=0.0.0.0
PROXY_PORT=5001
PROXY_THREADS=6

# Standard-Modell wenn keins angegeben
DEFAULT_MODEL=deepseek-chat

# Log-Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Modell-Whitelist (kommagetrennt, leer = alle)
# PERMITTED_MODELS=deepseek-chat,deepseek-reasoner,gpt-4o

# Nur erlaubte Modelle durchlassen (true/false)
RESTRICT_TO_PERMITTED=false

# Memcached für Rate Limiting (optional)
MEMCACHED_HOST=memcached
MEMCACHED_PORT=11211
