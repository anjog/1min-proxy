[Unit]
Description=1min.ai OpenAI-Compatible Proxy
After=network.target

[Service]
# Adjust User, Group and WorkingDirectory to match your setup
User=YOUR_USER
Group=YOUR_USER
WorkingDirectory=/path/to/1min-proxy
Environment="PATH=/path/to/1min-proxy/venv/bin:/usr/local/bin:/usr/bin:/bin"
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/path/to/1min-proxy/.env
ExecStart=/path/to/1min-proxy/venv/bin/python3 main.py
Restart=always
RestartSec=10
StandardOutput=append:/path/to/1min-proxy/proxy.log
StandardError=append:/path/to/1min-proxy/proxy.log

[Install]
WantedBy=multi-user.target
